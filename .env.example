# Optional: enables GPT-generated event preparation. The application remains usable
# with its deterministic local fallback when this value is absent.
OPENAI_API_KEY=
# Used by event research, prep, the interactive research chat, and public
# context checks. Defaults to gpt-5.6 when omitted.
OPENAI_RESEARCH_MODEL=gpt-5.6
# Optional. High-context follow-up synthesis defaults to GPT-5.6 when omitted.
OPENAI_FOLLOWUP_MODEL=gpt-5.6
# Optional. GPT decision calls default to high reasoning for reliable research,
# personalization, and follow-up organization. Lower only after evaluating quality.
OPENAI_REASONING_EFFORT=high
# Optional. Used for uploaded event screenshots. Defaults to OPENAI_RESEARCH_MODEL.
OPENAI_VISION_MODEL=gpt-5.6

# Required for deployed public QR cards and cross-device contact capture.
# Keep this server-only; do not expose it as NEXT_PUBLIC_*.
SUPABASE_URL=
# Required for Google login, magic links, and user-owned cloud workspaces.
# Use the public sb_publishable_... key from Supabase Settings > API Keys.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Preferred: the current sb_secret_... key from Supabase Settings > API Keys.
SUPABASE_SECRET_KEY=
# Legacy fallback only. Leave blank when using SUPABASE_SECRET_KEY.
SUPABASE_SERVICE_ROLE_KEY=
