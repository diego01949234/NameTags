# Optional: enables GPT-generated event preparation. The application remains usable
# with its deterministic local fallback when this value is absent.
OPENAI_API_KEY=
# GPT-5.6 Terra is the lower-cost GPT-5.6 option for the live event loop.
# Set gpt-5.6 explicitly when you need the higher-capability Sol model.
OPENAI_MODEL=gpt-5.6-terra
# Optional. Used only for short event-name/date searches that need live web research.
# Defaults to gpt-5.6 when omitted.
OPENAI_RESEARCH_MODEL=gpt-5.6

# Required for deployed public QR cards and cross-device contact capture.
# Keep this server-only; do not expose it as NEXT_PUBLIC_*.
SUPABASE_URL=
# Required for Google login, magic links, and user-owned cloud workspaces.
# Use the public sb_publishable_... key from Supabase Settings > API Keys.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Preferred: the current sb_secret_... key from Supabase Settings > API Keys.
SUPABASE_SECRET_KEY=
# Legacy fallback only. Leave blank when using SUPABASE_SECRET_KEY.
SUPABASE_SERVICE_ROLE_KEY=
